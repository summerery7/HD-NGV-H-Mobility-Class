<mujoco model="simple6dof-robot-handeye-vs">
  <option gravity="0 0 0" timestep="0.002"/>

  <compiler angle="radian" autolimits="true"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture name="texplane" type="2d" builtin="checker" mark="edge" markrgb="0.35 0.38 0.42"
             rgb1="0.19 0.21 0.24" rgb2="0.24 0.26 0.29" width="512" height="512"/>
    <material name="matplane" texture="texplane" texrepeat="6 6" texuniform="true"
              reflectance="0.15" shininess="0.4" specular="0.3"/>
    <material name="metal_dark"  rgba="0.25 0.27 0.32 1" shininess="0.6" specular="0.4"/>
    <material name="metal_light" rgba="0.75 0.77 0.80 1" shininess="0.6" specular="0.4"/>
    <material name="accent"      rgba="0.85 0.45 0.10 1" shininess="0.3" specular="0.3"/>

    <texture name="checkerboard_tex" type="cube" file="textures/checkerboard.png"/>
    <material name="checkerboard_mat" texture="checkerboard_tex"
              reflectance="0" shininess="0" specular="0" emission="0.3"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5" dir="0 0 -1" castshadow="false"/>
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1"/>
    <light directional="true" diffuse="0.5 0.5 0.5" specular="0.1 0.1 0.1" pos="2 0 1" dir="-1 0 -0.3" castshadow="false"/>
    <geom name="floor" size="2 2 0.01" type="plane" material="matplane"/>

    <camera name="overview" pos="1.1 -0.9 0.8" xyaxes="0.633 0.774 0 -0.372 0.304 0.877" fovy="45"/>

    <body name="board_stand" pos="0.55 0 0">
      <geom type="cylinder" size="0.015 0.22" pos="0 0 0.22" material="metal_dark" contype="0" conaffinity="0"/>
      <geom type="box" size="0.02 0.02 0.03" pos="0 0 0.47" material="metal_dark" contype="0" conaffinity="0"/>
    </body>
    <body name="checkerboard" pos="0.5285 0 0.48" quat="0.7071068 0 -0.7071068 0">
      <geom name="checkerboard_geom" type="box" size="0.048 0.048 0.0015"
            material="checkerboard_mat" contype="0" conaffinity="0"/>
      <site name="board_center" pos="0 0 0.0015" size="0.002" type="sphere" rgba="0 1 0 0.6"/>
    </body>

    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="cylinder" size="0.06 0.05" pos="0 0 0.05" material="metal_dark"/>
      <body name="link1" pos="0 0 0.10">
        <joint name="J1" axis="0 0 1" range="-3.14 3.14"/>
        <geom type="cylinder" size="0.045 0.035" pos="0 0 0.035" material="metal_light"/>
        <body name="link2" pos="0 0 0.07">
          <joint name="J2" axis="0 1 0" range="-2.0 2.0"/>
          <geom type="capsule" fromto="0 0 0  0 0 0.25" size="0.035" material="accent"/>
          <body name="link3" pos="0 0 0.25">
            <joint name="J3" axis="0 1 0" range="-2.6 2.6"/>
            <geom type="capsule" fromto="0 0 0  0 0 0.20" size="0.028" material="metal_light"/>
            <body name="link4" pos="0 0 0.20">
              <joint name="J4" axis="0 0 1" range="-3.14 3.14"/>
              <geom type="cylinder" size="0.025 0.025" pos="0 0 0.025" material="metal_dark"/>
              <body name="link5" pos="0 0 0.05">
                <joint name="J5" axis="0 1 0" range="-2.0 2.0"/>
                <geom type="capsule" fromto="0 0 0  0 0 0.04" size="0.022" material="accent"/>
                <body name="link6" pos="0 0 0.05">
                  <joint name="J6" axis="0 0 1" range="-3.14 3.14"/>
                  <geom name="flange" type="cylinder" size="0.020 0.008" pos="0 0 -0.008" material="metal_light"/>
                  <site name="tool_site" pos="0 0 0" size="0.004" type="sphere" rgba="1 0 0 0.6"/>

                  <geom name="cam_body" type="box" size="0.012 0.010 0.016" pos="0 -0.035 0.014"
                        material="metal_dark" contype="0" conaffinity="0"/>
                  <geom name="cam_lens" type="cylinder" size="0.006 0.004" pos="0 -0.035 0.034"
                        material="accent" contype="0" conaffinity="0"/>
                  <camera name="hand_eye" pos="0 -0.035 0.038" quat="0 1 0 0" fovy="45"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
