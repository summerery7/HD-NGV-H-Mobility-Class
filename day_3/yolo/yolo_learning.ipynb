    {
      "cell_type": "code",
      "source": [
        "import yaml\n",
        "\n",
        "# 2. 파일 읽기/쓰기 및 데이터 경로도 모두 yolo_dataset으로 변경\n",
        "with open('/content/yolo_dataset/data.yaml', 'r') as f:\n",
        "  data = yaml.load(f, Loader=yaml.FullLoader)\n",
        "\n",
        "data['train'] = '/content/yolo_dataset/train/images'\n",
        "data['val'] = '/content/yolo_dataset/valid/images'\n",
        "data['test'] = '/content/yolo_dataset/test/images'\n",
        "\n",
        "with open('/content/yolo_dataset/data.yaml', 'w') as f:\n",
        "  yaml.dump(data, f)\n",
        "print(data)"
      ],
      "metadata": {
